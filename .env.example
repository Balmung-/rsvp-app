# Core
# NODE_ENV is managed by the runtime:
#   - `next dev`   sets it to "development"
#   - `next build` and `next start` set it to "production"
#   - `vitest`     sets it to "test"
# Do NOT set it explicitly in Railway/host env. An explicit
# NODE_ENV=development during `next build` breaks the production
# build (prerender of /404 fails with a dev-only <Html> reference).
APP_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rsvp
AUTH_SECRET=change-me-32-bytes-hex
TOKEN_SIGNING_SECRET=change-me-32-bytes-hex
WEBHOOK_SHARED_SECRET=change-me-32-bytes-hex

# Defaults
DEFAULT_LOCALE=ar
DEFAULT_TIMEZONE=Asia/Riyadh

# Provider selection
SMS_PROVIDER=mock           # mock | twilio
EMAIL_PROVIDER=mock         # mock | resend

# Twilio (fill later, leave blank for mock)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_WEBHOOK_SIGNING_KEY=

# Resend (fill later, leave blank for mock)
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
EMAIL_FROM_DEFAULT="Ministry of Media <events@mom.example.sa>"

# Mock behavior
MOCK_AUTO_DELIVER=true
MOCK_AUTO_OPEN_RATE=0.7
MOCK_AUTO_CLICK_RATE=0.4
